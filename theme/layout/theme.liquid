<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#EDE6F4">
  <title>{{ page_title }}{% unless page_title contains shop.name %} &middot; {{ shop.name }}{% endunless %}</title>
  {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}

  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Jost:wght@300;400;500&family=Pinyon+Script&display=swap" rel="stylesheet">

  {{ 'base.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}
</head>
<body class="template-{{ request.page_type | handle }}">
  <div class="bh-frame">
    <div class="bh-orbs" aria-hidden="true">
      <div class="bh-orb bh-orb--1"></div>
      <div class="bh-orb bh-orb--2"></div>
      <div class="bh-orb bh-orb--3"></div>
    </div>

    {% sections 'header-group' %}

    <main id="main" class="bh-content">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}
  </div>
</body>
</html>

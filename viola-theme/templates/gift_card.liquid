{% layout none %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }} — Gift card</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500&family=Nunito+Sans:wght@400;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Nunito Sans', sans-serif; color: #1C1B1B; background: #F5F3F4; margin: 0; padding: 40px 20px; text-align: center; }
    .card { background: #fff; max-width: 420px; margin: 0 auto; padding: 40px 30px; border: 1px solid #E7E1E4; }
    h1 { font-family: 'Montserrat', sans-serif; font-weight: 500; font-size: 18px; letter-spacing: .25em; text-transform: uppercase; }
    .amount { font-size: 34px; font-weight: 700; margin: 18px 0; }
    .code { border: 1px dashed #1C1B1B; padding: 14px; font-size: 18px; letter-spacing: .18em; margin: 20px 0; }
    a.btn { display: inline-block; background: #1C1B1B; color: #fff; text-decoration: none; padding: 14px 28px;
      font-family: 'Montserrat', sans-serif; font-size: 12px; letter-spacing: .2em; text-transform: uppercase; }
  </style>
</head>
<body>
  <div class="card">
    <h1>{{ shop.name }}</h1>
    <p>Here's your gift card!</p>
    <div class="amount">{{ gift_card.initial_value | money }}</div>
    <div class="code">{{ gift_card.code | format_code }}</div>
    {%- if gift_card.enabled == false or gift_card.expired -%}
      <p>This gift card has expired.</p>
    {%- endif -%}
    <a class="btn" href="{{ shop.url }}">Shop now</a>
  </div>
</body>
</html>

{% layout 'password' %}
<div style="max-width:420px;">
  {%- form 'storefront_password' -%}
    {%- if form.errors -%}
      <div class="form-errors">{{ form.errors | default_errors }}</div>
    {%- endif -%}
    <label class="visually-hidden" for="password">Password</label>
    <div style="display:flex;">
      <input id="password" type="password" name="password" placeholder="Password" required
        style="flex:1; border:1px solid var(--ink); border-right:0; padding:12px 14px; font-family:var(--font-body);">
      <button class="btn btn--solid" style="padding:12px 20px;">Enter</button>
    </div>
  {%- endform -%}
</div>

<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }}</title>
  {{ content_for_header }}
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500&family=Nunito+Sans:wght@400;700&display=swap" rel="stylesheet">
  {{ 'viola.css' | asset_url | stylesheet_tag }}
  <style>
    :root { --ink:#1C1B1B; --paper:#fff; --blush:#F8E3EA; --blush-ink:#96435E; --muted:#6A6A6A; --tint:#F5F3F4; --line:#E7E1E4;
      --font-display:'Montserrat',sans-serif; --font-body:'Nunito Sans',sans-serif; }
  </style>
</head>
<body>
  <main style="min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:20px;">
    <div class="hdr__wordmark" style="color:var(--ink); font-family:var(--font-display); font-size:34px; letter-spacing:.5em; margin-right:-.5em; text-transform:uppercase;">Viola</div>
    <p class="eyebrow" style="margin:14px 0 40px;">Canada — opening soon</p>
    {{ content_for_layout }}
  </main>
</body>
</html>

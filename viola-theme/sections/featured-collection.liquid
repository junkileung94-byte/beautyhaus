<section class="block">
  <div class="wrap">
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
    <div class="grid">
      {%- for product in collections[section.settings.collection].products limit: section.settings.limit -%}
        {% render 'product-card', product: product %}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="card">
            <div class="card__media"></div>
            <div class="card__title">Product {{ i }}</div>
            <div class="card__price">$0.00</div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
    {%- if section.settings.cta_label != blank -%}
      <div style="text-align:center; margin-top: 36px;">
        <a class="btn" href="{{ collections[section.settings.collection].url | default: routes.all_products_collection_url }}">{{ section.settings.cta_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our best sellers" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "label": "Products", "min": 4, "max": 12, "step": 4, "default": 4 },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "View all products" }
  ],
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}

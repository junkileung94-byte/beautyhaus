{%- assign current_variant = product.selected_or_first_available_variant -%}

<div class="wrap">
  <nav class="breadcrumbs" aria-label="Breadcrumbs">
    <a href="{{ routes.root_url }}">Home</a>
    {%- if collection -%} › <a href="{{ collection.url }}">{{ collection.title }}</a>{%- endif -%}
    › {{ product.title }}
  </nav>

  <div class="pdp">
    <div class="pdp__gallery">
      <img data-pdp-image
        src="{{ current_variant.featured_image | default: product.featured_image | image_url: width: 1100 }}"
        alt="{{ product.featured_image.alt | default: product.title | escape }}"
        width="1100" height="1100">
      {%- if product.images.size > 1 -%}
        <div class="pdp__thumbs">
          {%- for image in product.images limit: 8 -%}
            <button type="button" data-pdp-thumb data-src="{{ image | image_url: width: 1100 }}"
              class="{% if forloop.first %}is-active{% endif %}" aria-label="View image {{ forloop.index }}">
              <img src="{{ image | image_url: width: 128 }}" alt="" loading="lazy" width="64" height="64">
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <div class="pdp__info">
      <h1 class="pdp__title">{{ product.title }}</h1>
      <div class="pdp__price">
        <span data-pdp-price>{{ current_variant.price | money }}</span>
        <s data-pdp-compare {% unless current_variant.compare_at_price > current_variant.price %}style="display:none"{% endunless %}>
          {{- current_variant.compare_at_price | money -}}
        </s>
      </div>

      {%- form 'product', product, data-product-form: '', data-money-format: shop.money_format -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}">

        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <label for="option-{{ section.id }}-{{ forloop.index0 }}">{{ option.name }}</label>
            <select id="option-{{ section.id }}-{{ forloop.index0 }}" data-option-select>
              {%- for value in option.values -%}
                <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
              {%- endfor -%}
            </select>
          {%- endfor -%}
        {%- endunless -%}

        <label for="qty-{{ section.id }}">{{ 'products.product.quantity' | t }}</label>
        <div class="qty">
          <button type="button" data-step="down" aria-label="Decrease quantity">−</button>
          <input id="qty-{{ section.id }}" type="number" name="quantity" value="1" min="1" inputmode="numeric">
          <button type="button" data-step="up" aria-label="Increase quantity">+</button>
        </div>

        <button type="submit" class="btn btn--solid btn--full" data-add-to-cart
          data-text-add="{{ 'products.product.add_to_cart' | t }}"
          data-text-soldout="{{ 'products.product.sold_out' | t }}"
          data-text-unavailable="{{ 'products.product.unavailable' | t }}"
          {% unless current_variant.available %}disabled{% endunless %}>
          {%- if current_variant.available -%}{{ 'products.product.add_to_cart' | t }}{%- else -%}{{ 'products.product.sold_out' | t }}{%- endif -%}
        </button>
      {%- endform -%}

      {%- if product.tags contains 'LUXE' and section.settings.show_trade_note -%}
        <div class="pdp__trade">{{ 'products.product.trade_only' | t }}</div>
      {%- endif -%}

      <div class="accordions">
        {%- if product.description != blank -%}
          <details open>
            <summary>{{ 'products.product.description' | t }}</summary>
            <div class="rte">{{ product.description }}</div>
          </details>
        {%- endif -%}
        {%- if product.metafields.custom.details != blank -%}
          <details>
            <summary>{{ 'products.product.details' | t }}</summary>
            <div class="rte">{{ product.metafields.custom.details | metafield_tag }}</div>
          </details>
        {%- endif -%}
        {%- if product.metafields.custom.for_use != blank -%}
          <details>
            <summary>{{ 'products.product.for_use' | t }}</summary>
            <div class="rte">{{ product.metafields.custom.for_use | metafield_tag }}</div>
          </details>
        {%- endif -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.heading != blank and block.settings.body != blank -%}
            <details {{ block.shopify_attributes }}>
              <summary>{{ block.settings.heading }}</summary>
              <div class="rte">{{ block.settings.body }}</div>
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<script type="application/json" data-variants-json>
  {{ product.variants | json }}
</script>

{% schema %}
{
  "name": "Product page",
  "settings": [
    { "type": "checkbox", "id": "show_trade_note", "label": "Show trade-account note on LUXE-tagged products", "default": true }
  ],
  "blocks": [
    {
      "type": "accordion", "name": "Extra accordion",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shipping & returns" },
        { "type": "richtext", "id": "body", "label": "Body" }
      ]
    }
  ],
  "max_blocks": 3
}
{% endschema %}

<div class="wrap">
  <header class="coll-head">
    <h1>{{ collection.title }}</h1>
  </header>

  {%- paginate collection.products by section.settings.per_page -%}
    <div class="coll-toolbar">
      <label class="visually-hidden" for="sort-by">Sort</label>
      <select id="sort-by" onchange="var u=new URL(location); u.searchParams.set('sort_by', this.value); location=u;"
        style="border:1px solid var(--line); padding:9px 12px; font-family:var(--font-body); font-size:12.5px; background:var(--paper); color:var(--ink);">
        {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
        {%- for option in collection.sort_options -%}
          <option value="{{ option.value }}" {% if option.value == sort_by %}selected{% endif %}>{{ option.name }}</option>
        {%- endfor -%}
      </select>
    </div>

    {%- if collection.products.size > 0 -%}
      <div class="grid">
        {%- for product in collection.products -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      </div>
    {%- else -%}
      <p style="text-align:center; color:var(--muted); padding: 40px 0;">{{ 'collections.general.no_products' | t }}</p>
    {%- endif -%}

    {%- if paginate.pages > 1 -%}
      <nav class="pagination" aria-label="Pagination">
        {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">‹ {{ 'general.pagination.previous' | t }}</a>{%- endif -%}
        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}
            <a href="{{ part.url }}">{{ part.title }}</a>
          {%- elsif part.title == paginate.current_page -%}
            <span class="current">{{ part.title }}</span>
          {%- else -%}
            <span>{{ part.title }}</span>
          {%- endif -%}
        {%- endfor -%}
        {%- if paginate.next -%}<a href="{{ paginate.next.url }}">{{ 'general.pagination.next' | t }} ›</a>{%- endif -%}
      </nav>
    {%- endif -%}
  {%- endpaginate -%}

  {%- comment -%} Long-form SEO/education copy below the grid — the UK pattern {%- endcomment -%}
  {%- if collection.description != blank -%}
    <div class="coll-desc rte">{{ collection.description }}</div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Collection page",
  "settings": [
    { "type": "range", "id": "per_page", "label": "Products per page", "min": 12, "max": 48, "step": 4, "default": 24 }
  ]
}
{% endschema %}

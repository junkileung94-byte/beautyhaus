<div class="wrap page-body">
  <header class="coll-head"><h1>{{ blog.title }}</h1></header>
  {%- paginate blog.articles by 12 -%}
    <div class="grid" style="grid-template-columns: repeat(3, 1fr);">
      {%- for article in blog.articles -%}
        <a class="card" href="{{ article.url }}">
          {%- if article.image -%}
            <div class="card__media" style="aspect-ratio: 4/3;">
              <img src="{{ article.image | image_url: width: 600 }}" alt="" loading="lazy" width="600" height="450">
            </div>
          {%- endif -%}
          <div class="card__title">{{ article.title }}</div>
          <div class="card__price">{{ article.published_at | date: '%B %d, %Y' }}</div>
        </a>
      {%- endfor -%}
    </div>
    {%- if paginate.pages > 1 -%}
      <nav class="pagination">
        {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">‹</a>{%- endif -%}
        {%- if paginate.next -%}<a href="{{ paginate.next.url }}">›</a>{%- endif -%}
      </nav>
    {%- endif -%}
  {%- endpaginate -%}
</div>

{% schema %}
{ "name": "Blog", "settings": [] }
{% endschema %}
